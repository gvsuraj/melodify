{
  "name": "melodify",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,green \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "node server/index.js",
    "postinstall": "npm --prefix server install",
    "build": "tsc -b && vite build",
    "start": "node server/index.js",
    "preview": "vite preview",
    "seed": "node scripts/seedSongs.js"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "concurrently": "^9.1.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "firebase": "^12.14.0",
    "firebase-admin": "^14.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.17.0"
  }
}
